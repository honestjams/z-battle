{
  "version": "1.0",
  "meta": {
    "game": "Z-Battle",
    "structure": "Catalog of unique card definitions in `cards`, referenced by `decks`. Shared items (e.g. senzu_bean) are defined once and listed in multiple decks.",
    "constants": {
      "koToWin": 3,
      "kiStart": 1,
      "kiPerTurn": 1,
      "kiCap": 8,
      "handLimit": 7,
      "activeSlots": 2,
      "benchSlots": 2,
      "maxEquipmentPerFighter": 2,
      "basicAttackDamage": "max(attackerAtk - targetDef, 1000)",
      "flatDamageHasNoMinimum": true,
      "openingHandSize": 5,
      "openingDrawPile": "hero",
      "openingRedrawUntil": "hand contains at least one hero with kiCost 1"
    },
    "fighterTypes": ["earthling", "saiyan", "namekian", "android", "frieza_force"],
    "abilityKinds": [
      "conditional", "permanent_counter", "triggered_on_ko", "triggered_on_deal_damage",
      "triggered_on_play", "triggered_end_of_turn", "activated_on_attack", "ultimate",
      "one_shot_on_attack", "activated_one_shot", "static_modifier",
      "heal", "attach_stat", "attach_trigger", "direct_damage", "delayed_damage",
      "draw", "reveal_and_draw", "remove_summoning_sickness", "prevent_damage",
      "sacrifice_for_damage", "recur_from_discard",
      "field_flat_damage", "field_flat_buff", "field_type_buff", "field_type_heal"
    ],
    "note_on_self_ko": "Per ruleset, any removal except a voluntary Sacrifice counts as a KO that scores for the opponent. Abilities flagged countsAsKo:true (android_16, self_destruct_device) give the opponent a point."
  },

